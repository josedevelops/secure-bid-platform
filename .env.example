# .env.example — copy this to .env and fill in your values
# cp .env.example .env
# never commit .env — it contains secrets
# this file is safe to commit — it shows what variables are required

# --- App ---
APP_NAME=Secure Bid Platform
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# --- Database ---
# format: postgresql+asyncpg://user:password@host:port/dbname
# host is 'db' when running in Docker — matches the service name in docker-compose
DATABASE_URL=postgresql+asyncpg://appuser:changeme@db:5432/securebid
POSTGRES_USER=appuser
POSTGRES_PASSWORD=changeme
POSTGRES_DB=securebid

# --- Security ---
# generate a secure key with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- CORS ---
# list of allowed frontend origins — add your frontend URL in production
ALLOWED_ORIGINS=["http://localhost:3000"]
